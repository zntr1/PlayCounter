# PlayCounter — shared environment for the API and the IGDB seed scripts.
# Copy this file to `apps/.env` and fill in your own values.
# `apps/.env` is gitignored and must never be committed.

# --- Database (optional for local dev) ---------------------------------------
# Without DATABASE_URL the API falls back to a small in-memory sample catalog,
# which is enough to run and develop against. Set it to a real Postgres
# connection string for persistence and to run migrations / seeding.
# DATABASE_URL=postgresql://user:password@localhost:5432/playcounter?sslmode=disable

# --- Server (optional) -------------------------------------------------------
# HTTP port the API listens on. Defaults to 4000.
# PORT=4000
# Max concurrent live-feed WebSocket connections. Defaults to 10000.
# LIVE_MAX_CONNECTIONS=10000

# --- IGDB matching (optional) ------------------------------------------------
# Enables IGDB lookups for unknown executables and the seed scripts.
# IGDB uses Twitch OAuth: provide a client id, plus EITHER a ready-made access
# token OR a client secret the app can exchange for a token.
# Get credentials at https://dev.twitch.tv/console/apps
# IGDB_CLIENT_ID=your_twitch_client_id
# TWITCH_CLIENT_ID=your_twitch_client_id
# IGDB_ACCESS_TOKEN=your_prefetched_igdb_access_token
# TWITCH_CLIENT_SECRET=your_twitch_client_secret

# --- IGDB seed tuning (optional, used by scripts/igdb-seed) ------------------
# IGDB_BATCH_SIZE=500
# IGDB_REQUEST_DELAY_MS=250
# IGDB_SEED_LIMIT=1000
# IGDB_START_AFTER_ID=0
# IGDB_GAME_ID=1020
