{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlayCounter",
  "version": "1.0.5",
  "identifier": "app.playcounter.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build:prod",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PlayCounter",
        "width": 1460,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/covers/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zntr1/PlayCounter/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4RjM0OTY4QkNFMzE2QzYKUldUR0Z1TzhhRW56NkhGdWIxR0w3Yy80MXNhdi9iWDV6dHlhMmtjUkoxSUtUNVRSOGd3bzBrTWcK"
    }
  }
}
